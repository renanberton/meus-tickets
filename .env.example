# ===========================================
#  Banco de Dados MySQL
# ===========================================
MYSQL_ROOT_PASSWORD=root123
MYSQL_DATABASE=meus_tickets

# ===========================================
#  Spring Boot (Backend)
# ===========================================
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/meus_tickets?useSSL=false&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=root123
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# ===========================================
#  Segurança JWT
# ===========================================
JWT_SECRET=chave-super-secreta-para-testes

# ===========================================
#  Integração HubSpot (OBRIGATÓRIO)
# ===========================================
HUBSPOT_TOKEN=seu-token-aqui